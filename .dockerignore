data/vector_db/

# Dữ liệu thô (đã xử lý, không cần trong container)
data/raw/
data/raw_v2/
data/archive/
data/archive.zip
data/embeddings/
data/processed/

# Log files
data/*.log
data/*.json
data/*.txt

